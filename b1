set serveroutput on;
CREATE OR REPLACE FUNCTION area_circle(r NUMBER)
RETURN NUMBER
IS
    area NUMBER;
BEGIN
    area := 3.14  r * r;
    RETURN area;
END;
/
DECLARE
    result NUMBER;
BEGIN
    result := area_circle(5);
    DBMS_OUTPUT.PUT_LINE('Area = ' || result);
END;
/
